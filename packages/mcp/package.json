{
	"name": "@listmonk-ops/mcp",
	"version": "0.1.0",
	"description": "Listmonk Model Context Protocol Server using Hono",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"test": "bun test",
