		"dotenv": "17.3.1",
		"hono": "4.12.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/node": "25.3.3",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	}
}
