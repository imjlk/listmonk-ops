{
	"name": "@listmonk-ops/mcp",
	"version": "0.1.0",
	"description": "Listmonk Model Context Protocol Server using Hono",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"listmonk-mcp": "bin/listmonk-mcp.js"
	},
	"type": "module",
	"files": [
