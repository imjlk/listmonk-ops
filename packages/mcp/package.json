{
	"name": "@listmonk-ops/mcp",
	"version": "0.4.0",
	"description": "Listmonk Model Context Protocol Server using Hono",
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"listmonk-mcp": "bin/listmonk-mcp.js"
	},
	"type": "module",
	"files": [
		"dist",
		"bin",
		"README.md"
	],
	"scripts": {
		"dev": "bun src/index.ts",
		"build": "ttsc",
		"start": "bun dist/index.js",
		"test": "bun run --cwd ../common build && bun run --cwd ../openapi build && bun run --cwd ../operations build && bun run --cwd ../automation build && bun run --cwd ../abtest build && bun run build && bun test tests/unit",
		"test:e2e": "bun test tests/e2e",
		"typecheck": "ttsc --noEmit",
		"format": "ttsc format",
		"lint": "ttsc --noEmit",
		"lint:fix": "ttsc fix",
		"prepublishOnly": "bun run test"
	},
	"dependencies": {
		"@listmonk-ops/abtest": "workspace:^0.3.1",
		"@listmonk-ops/automation": "workspace:^0.1.7",
		"@listmonk-ops/common": "workspace:^0.3.0",
		"@listmonk-ops/openapi": "^0.3.0",
		"@listmonk-ops/operations": "workspace:^0.3.0",
		"@modelcontextprotocol/sdk": "1.27.1",
		"hono": "4.12.7"
	},
	"devDependencies": {
		"@types/node": "25.3.3",
		"typescript": "7.0.2"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
