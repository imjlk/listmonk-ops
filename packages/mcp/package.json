{
	"name": "@listmonk-ops/mcp",
	"version": "0.1.1",
	"description": "Listmonk Model Context Protocol Server using Hono",
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"listmonk-mcp": "bin/listmonk-mcp.js"
	},
	"type": "module",
	"files": [
		"dist",
		"bin",
		"README.md"
	],
	"scripts": {
		"dev": "bun src/index.ts",
		"build": "tsc",
		"start": "bun dist/index.js",
		"test": "bun run --cwd ../common build && bun run --cwd ../openapi build && bun run --cwd ../automation build && bun run --cwd ../abtest build && bun run build && bun test tests/unit",
		"test:e2e": "bun test tests/e2e",
		"lint": "biome check src",
		"lint:fix": "biome check src --fix",
		"prepublishOnly": "bun run test"
	},
	"dependencies": {
		"@listmonk-ops/abtest": "^0.1.1",
		"@listmonk-ops/automation": "^0.1.1",
		"@modelcontextprotocol/sdk": "1.27.1",
		"dotenv": "17.3.1",
		"hono": "4.12.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/node": "25.3.3",
		"tsx": "4.21.0",
		"typescript": "5.9.3"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
