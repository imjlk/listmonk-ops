# Test environment configuration for MCP E2E tests.
# Copy this to .env.test.local and adjust as needed.

# Listmonk server configuration (defaults target the local Docker stack)
LISTMONK_API_URL=http://localhost:9000/api
LISTMONK_USERNAME=api-admin
# Leave empty to provision a local token through Listmonk's /api/users endpoint.
LISTMONK_API_TOKEN=

# Test configuration
TEST_TIMEOUT=30000
TEST_CLEANUP=true

# Optional: set to 1 only when you intentionally run against a non-local target.
LISTMONK_E2E_ALLOW_REMOTE=0
