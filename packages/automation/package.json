{
	"name": "@listmonk-ops/automation",
	"version": "0.1.2",
	"type": "module",
	"description": "High-level Listmonk operational automation workflows",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun run clean && tsc --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --minify --external:@listmonk-ops/openapi",
		"test": "bun test",
		"prepublishOnly": "bun run build && bun run test"
	},
	"dependencies": {
		"@listmonk-ops/openapi": "^0.1.4"
	},
	"devDependencies": {
		"@types/bun": "1.3.10",
		"esbuild": "0.27.4",
		"typescript": "5.9.3"
	}
}
