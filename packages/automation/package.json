{
	"name": "@listmonk-ops/automation",
	"version": "0.1.6",
	"type": "module",
	"description": "High-level Listmonk operational automation workflows",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun run clean && ttsc --emitDeclarationOnly && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --minify --external:@listmonk-ops/common --external:@listmonk-ops/openapi --external:@listmonk-ops/operations --external:zod",
		"typecheck": "ttsc --noEmit",
		"format": "ttsc format",
		"lint": "ttsc --noEmit",
		"lint:fix": "ttsc fix",
		"test": "bun run --cwd ../common build && bun test",
		"prepublishOnly": "bun run build && bun run test"
	},
	"dependencies": {
		"@listmonk-ops/common": "^0.2.0",
		"@listmonk-ops/openapi": "^0.2.0",
		"@listmonk-ops/operations": "workspace:^",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.10",
		"esbuild": "0.27.4",
		"typescript": "7.0.2"
	}
}
