{
	"name": "@listmonk-ops/openapi",
	"version": "0.1.4",
	"description": "Type-safe Listmonk OpenAPI SDK with flattened response helpers",
	"type": "module",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./sdk": {
			"types": "./dist/sdk.d.ts",
			"import": "./dist/sdk.js",
			"default": "./dist/sdk.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"generate": "bun run generate.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"build": "bun run clean && bun run generate && tsc && esbuild index.ts sdk.ts --bundle --outdir=dist --format=esm --minify",
		"prepublishOnly": "bun run build && bun run test"
	},
	"devDependencies": {
		"@hey-api/openapi-ts": "0.94.1",
		"@types/bun": "1.3.10",
		"esbuild": "0.27.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
