{
	"name": "@listmonk-ops/cli",
	"version": "0.3.0",
	"description": "Listmonk operations CLI built with Gunshi and Bun",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"bin": {
		"listmonk-cli": "dist/js/index.js"
	},
	"main": "./dist/js/index.js",
	"module": "./dist/js/index.js",
	"files": [
		"dist/js",
		"README.md"
	],
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"clean": "rm -rf ./dist",
		"dev": "bun --watch src/index.ts",
		"build:js": "bun build src/index.ts --target=bun --minify --outdir=dist/js",
		"build:bin": "bun ./scripts/build-binary.ts",
		"build:bin:all": "bun ./scripts/build-binary.ts --all",
		"build": "bun run typecheck && bun run clean && bun run build:js && bun run build:bin",
		"start": "bun src/index.ts",
		"typecheck": "ttsc --noEmit",
		"format": "ttsc format",
		"lint": "ttsc --noEmit",
		"lint:fix": "ttsc fix",
		"test": "bun run typecheck && bun test tests",
		"test:binary": "CLI_TEST_EXECUTABLE=./dist/bin/listmonk-cli bun test tests",
		"prepublishOnly": "bun run build && bun run test && bun run test:binary"
	},
	"dependencies": {
		"@clack/prompts": "0.10.1",
		"@gunshi/plugin-completion": "0.37.1",
		"@listmonk-ops/abtest": "^0.2.0",
		"@listmonk-ops/common": "^0.2.0",
		"@listmonk-ops/automation": "^0.1.3",
		"@listmonk-ops/openapi": "^0.2.0",
		"@listmonk-ops/operations": "^0.1.0",
		"gunshi": "0.37.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.10",
		"typescript": "7.0.2"
	}
}
