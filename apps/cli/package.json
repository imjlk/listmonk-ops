{
	"name": "@listmonk-ops/cli",
	"version": "0.2.2",
	"description": "Listmonk operations CLI built with Bunli",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/imjlk/listmonk-ops"
	},
	"bin": {
		"listmonk-cli": "dist/js/index.js"
	},
	"main": "./dist/js/index.js",
	"module": "./dist/js/index.js",
	"files": [
		"dist/js",
		"dist/.bunli",
		"README.md"
	],
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"clean": "rm -rf ./dist ./.bunli",
		"generate": "bunli generate --entry ./src/index.ts && bun run generate:completion-metadata",
		"generate:completion-metadata": "bun ./scripts/generate-completion-metadata.ts",
		"copy:completion-metadata": "mkdir -p ./dist/bin ./dist/.bunli && cp ./.bunli/commands.runtime.mjs ./dist/bin/commands.runtime.mjs && cp ./.bunli/commands.runtime.mjs ./dist/.bunli/commands.runtime.mjs",
		"dev": "bunli dev --entry ./src/index.ts",
		"build:js": "bunli build --entry ./src/index.ts --outdir ./dist/js --runtime bun",
		"build:bin": "bunli build --entry ./src/index.ts --outdir ./dist/bin --targets native --outfile ./dist/bin/listmonk-cli",
		"build:bin:all": "bunli build --entry ./src/index.ts --outdir ./dist/bin --targets all",
		"build": "bun run clean && bun run generate && bun run build:js && bun run build:bin && bun run copy:completion-metadata",
		"start": "bun src/index.ts",
		"doctor:completions": "bunli doctor completions",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@bunli/core": "0.7.0",
		"@bunli/plugin-completions": "0.3.3",
		"@bunli/utils": "0.4.0",
		"@listmonk-ops/abtest": "^0.1.2",
		"@listmonk-ops/common": "^0.1.2",
		"@listmonk-ops/automation": "^0.1.2",
		"@listmonk-ops/openapi": "^0.1.4",
		"bunli": "0.7.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.10",
		"typescript": "5.9.3"
	}
}
