{
	"name": "listmonk-ops",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@ttsc/graph": "0.19.3",
		"@ttsc/lint": "0.19.3",
		"@types/bun": "^1.3.10",
		"@types/node": "^26.1.1",
		"ttsc": "0.19.3",
		"typescript": "7.0.2"
	},
	"scripts": {
		"cli": "bash ./scripts/ensure-runtime-deps.sh && bun --cwd apps/cli src/index.ts",
		"api": "bun run --cwd packages/openapi --",
		"mcp": "bash ./scripts/ensure-runtime-deps.sh && bun run --cwd packages/mcp --",
		"build": "bun run --cwd packages/common build && bun run --cwd packages/openapi build && bun run --cwd packages/operations build && bun run --cwd packages/automation build && bun run --cwd packages/abtest build && bun run --cwd apps/cli build && bun run --cwd packages/mcp build",
		"test": "bun run test:scripts && bun run --cwd packages/openapi test && bun run --cwd packages/operations test && bun run --cwd packages/automation test && bun run --cwd packages/abtest test && bun run --cwd apps/cli test && bun run --cwd packages/mcp test",
		"test:scripts": "bun test scripts",
		"test:e2e": "bun run --cwd packages/mcp test:e2e",
		"test:all": "bun run test && bun run test:e2e",
		"release:add": "sampo add",
		"release:check": "bash ./scripts/check-sampo-changeset.sh",
		"release:plan": "sampo release --dry-run",
		"release:apply": "sampo release",
		"release:publish": "bash ./scripts/sampo-publish.sh -- --access public",
		"release:publish:dry": "bash ./scripts/sampo-publish.sh --dry-run -- --access public",
		"release:publish:oidc": "bash ./scripts/sampo-publish.sh -- --access public --provenance",
		"release:publish:oidc:dry": "bash ./scripts/sampo-publish.sh --dry-run -- --access public --provenance",
		"stack:bootstrap-auth": "bun run ./scripts/bootstrap-listmonk-test-auth.ts",
		"ops:smoke": "bash ./scripts/ops-smoke.sh",
		"ops:smoke:full": "LISTMONK_OPS_SMOKE_MODE=full bash ./scripts/ops-smoke.sh",
		"check:cli-pack-size": "bash ./scripts/check-cli-pack-size.sh",
		"format": "ttsc format -p tsconfig.quality.json",
		"lint": "ttsc --noEmit --noCheck -p tsconfig.quality.json",
		"lint:fix": "ttsc fix --noCheck -p tsconfig.quality.json",
		"typecheck": "ttsc --noEmit -p tsconfig.typecheck.json",
		"check": "bun run lint && bun run typecheck && bun run graph:check",
		"graph:check": "bun run ./scripts/check-graph-tests.ts && ttsc-graph dump --cwd . --tsconfig tsconfig.graph.json >/dev/null",
		"graph:mcp": "ttsc-graph --cwd . --tsconfig tsconfig.graph.json",
		"graph:dump": "ttsc-graph dump --cwd . --tsconfig tsconfig.graph.json",
		"graph:view": "ttsc-graph view --cwd . --tsconfig tsconfig.graph.json"
	},
	"workspaces": {
		"packages": [
			"packages/*",
			"apps/*"
		]
	}
}
