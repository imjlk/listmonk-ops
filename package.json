{
	"name": "listmonk-ops",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.3.10"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"scripts": {
		"cli": "bash ./scripts/ensure-runtime-deps.sh && bun --cwd apps/cli src/index.ts",
		"api": "bun run --cwd packages/openapi --",
		"mcp": "bash ./scripts/ensure-runtime-deps.sh && bun run --cwd packages/mcp --",
		"build": "bun run --cwd apps/cli build && bun run --cwd packages/openapi build && bun run --cwd packages/automation build && bun run --cwd packages/abtest build && bun run --cwd packages/mcp build",
		"test": "bun run --cwd packages/openapi test && bun run --cwd packages/abtest test",
		"test:e2e": "bun run --cwd packages/mcp test:e2e",
		"test:all": "bun run test && bun run test:e2e",
		"release:add": "sampo add",
		"release:check": "bash ./scripts/check-sampo-changeset.sh",
		"release:plan": "sampo release --dry-run",
		"release:apply": "sampo release",
		"release:publish": "bash ./scripts/sampo-publish.sh -- --access public",
		"release:publish:dry": "bash ./scripts/sampo-publish.sh --dry-run -- --access public",
		"release:publish:oidc": "bash ./scripts/sampo-publish.sh -- --access public --provenance",
		"release:publish:oidc:dry": "bash ./scripts/sampo-publish.sh --dry-run -- --access public --provenance",
		"ops:smoke": "bash ./scripts/ops-smoke.sh",
		"ops:smoke:full": "LISTMONK_OPS_SMOKE_MODE=full bash ./scripts/ops-smoke.sh",
		"format": "biome format --write"
	},
	"workspaces": {
		"packages": [
			"packages/*",
			"apps/*"
		]
	}
}
